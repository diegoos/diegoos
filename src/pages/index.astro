---
import { Font } from 'astro:assets';
import '../styles/global.scss';

const title = 'Diego Oliveira';
const description =
  'Fullstack software engineer with 13 years building digital products, architecture, and infrastructure. Exploring AI tooling, own products, and always learning.';
const site = 'https://diegoos.com';
const socialImage = new URL('/social.png', site).href;

const social = [
  {
    name: 'LinkedIn',
    href: 'https://www.linkedin.com/in/diegoos',
    icon: 'linkedin',
  },
  {
    name: 'GitHub',
    href: 'https://github.com/diegoos',
    icon: 'github',
  },
  {
    name: 'X (Twitter)',
    href: 'https://twitter.com/didiegoos',
    icon: 'x',
  },
];
---

<html lang='en'>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <meta name='description' content={description} />

    <title>{title}</title>

    <link rel='canonical' href={site} />
    <link rel='manifest' href='/site.webmanifest' />
    <link rel='icon' href='/favicon.ico' sizes='any' />
    <link rel='icon' type='image/png' sizes='32x32' href='/favicon-32x32.png' />
    <link rel='icon' type='image/png' sizes='16x16' href='/favicon-16x16.png' />
    <link rel='apple-touch-icon' href='/apple-touch-icon.png' />

    <meta property='og:type' content='website' />
    <meta property='og:url' content={site} />
    <meta property='og:title' content={title} />
    <meta property='og:description' content={description} />
    <meta property='og:locale' content='en_US' />
    <meta property='og:image' content={socialImage} />
    <meta property='og:image:alt' content={title} />

    <meta name='twitter:card' content='summary_large_image' />
    <meta name='twitter:title' content={title} />
    <meta name='twitter:description' content={description} />
    <meta name='twitter:image' content={socialImage} />

    <meta name='author' content='Diego Oliveira' />

    <Font cssVariable='--font-noto-sans' preload />
  </head>
  <body>
    <main class='page' id='page'>
      <div class='page__grid page__grid--base' aria-hidden='true'></div>
      <div class='page__grid page__grid--focus' aria-hidden='true'></div>
      <svg class='page__bolts' aria-hidden='true'></svg>

      <div class='hero'>
        <div class='stagger' id='hero-stagger'>
          <p class='stagger__line hero__greeting'>Hi, I'm</p>
          <h1 class='stagger__line stagger__line--name hero__name'>
            Diego Oliveira
          </h1>
          <p class='stagger__line stagger__line--bio hero__bio'>
            Fullstack software engineer with 13 years building digital products,
            architecture, and infrastructure. Currently exploring AI tooling for
            development, own products, and growing as a senior engineer.
          </p>
        </div>

        <nav aria-label='Social'>
          <ul class='social'>
            {
              social.map((link) => (
                <li>
                  <a
                    class='social__link'
                    href={link.href}
                    target='_blank'
                    rel='noopener noreferrer'
                    aria-label={link.name}>
                    {link.icon === 'linkedin' && (
                      <svg
                        class='social__icon'
                        viewBox='0 0 24 24'
                        aria-hidden='true'>
                        <path d='M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 114.127 0 2.062 2.062 0 01-2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z' />
                      </svg>
                    )}
                    {link.icon === 'github' && (
                      <svg
                        class='social__icon'
                        viewBox='0 0 24 24'
                        aria-hidden='true'>
                        <path d='M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12' />
                      </svg>
                    )}
                    {link.icon === 'x' && (
                      <svg
                        class='social__icon'
                        viewBox='0 0 24 24'
                        aria-hidden='true'>
                        <path d='M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z' />
                      </svg>
                    )}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
    </main>
  </body>
</html>

<script>
  import { initHeroStagger } from '../modules/hero-stagger';
  import { initGridEnergy } from '../modules/grid-energy';

  initHeroStagger();
  initGridEnergy();
</script>
